---
import type { Cooperativa } from '@/types';
import {
  diferenciadorTexto,
  enlaceWhatsapp,
  etiquetaPublica,
  imgOnErrorAttr,
  itemsGaleria,
  programasPublicos,
  resolverCta,
  resolverImagenPrincipal,
  resolverLogo,
  serviciosLista,
  sitiosWebLista,
  textoSeguro,
} from '@/lib/cooperativa';
import SpacesigDemosPortafolio from '@/components/SpacesigDemosPortafolio.astro';
import { ORGANIZACION_DESTACADA_ID } from '@/data/cooperativas';

interface Props {
  cooperativa: Cooperativa;
  mostrarEncabezadoPortal?: boolean;
}

const { cooperativa, mostrarEncabezadoPortal = true } = Astro.props;

const logo = resolverLogo(cooperativa);
const portada = resolverImagenPrincipal(cooperativa);
const galeria = itemsGaleria(cooperativa);
const servicios = serviciosLista(cooperativa);
const programas = programasPublicos(cooperativa);
const sitiosWeb = sitiosWebLista(cooperativa);
const cta = resolverCta(cooperativa);
const whatsappUrl = enlaceWhatsapp(cooperativa.whatsapp);
const imgErr = imgOnErrorAttr();
const etiqueta = etiquetaPublica(cooperativa);
const diferenciador = diferenciadorTexto(cooperativa);

const giro = textoSeguro(cooperativa.giro);
const zona = textoSeguro(cooperativa.zona);
const horario = textoSeguro(cooperativa.horario);
const correo = textoSeguro(cooperativa.correo);
const descripcionCorta = textoSeguro(cooperativa.descripcionCorta);
const descripcionLarga = textoSeguro(cooperativa.descripcionLarga, descripcionCorta);
const sitioPrincipal = sitiosWeb[0] ?? '';
const ctaExterno = cta?.url.startsWith('http') ?? false;
const mostrarDemosSpacesig = cooperativa.id === ORGANIZACION_DESTACADA_ID;

function etiquetaSitio(url: string): string {
  try {
    const host = new URL(url).hostname.replace(/^www\./, '');
    return host || 'Sitio web';
  } catch {
    return 'Sitio web';
  }
}
---

<article class="ficha-destacada" aria-labelledby="ficha-destacada-titulo">
  {
    mostrarEncabezadoPortal && (
      <p class="ficha-destacada-aviso">
        <span class="badge-destacado">{etiqueta}</span>
        <span class="mt-2 block text-sm text-slate-600">
          Primera ficha ampliada del portal colectivo. SPACESIG impulsa la plataforma como aliado
          tecnológico; las cooperativas participantes se integrarán al directorio conforme compartan
          su información.
        </span>
      </p>
    )
  }

  <div class="ficha-destacada-hero">
    <figure class="ficha-destacada-portada" role="img" aria-label={`Portada de ${cooperativa.nombre}`}>
      <img
        src={portada}
        alt={`Imagen de portada de ${cooperativa.nombre}`}
        class="ficha-destacada-portada-img"
        width="1920"
        height="520"
        fetchpriority="high"
        onerror={imgErr}
      />
    </figure>
    <div class="ficha-destacada-encabezado">
      <img
        src={logo}
        alt={`Logotipo de ${cooperativa.nombre}`}
        class="ficha-destacada-logo"
        width="96"
        height="96"
        onerror={imgErr}
      />
      <div class="min-w-0 flex-1">
        <p class="text-xs font-semibold uppercase tracking-wide text-xochimilco-green">
          {etiqueta}
        </p>
        <h2 id="ficha-destacada-titulo" class="mt-1 text-2xl font-bold text-alcaldia-900 sm:text-3xl">
          {cooperativa.nombre}
        </h2>
        {textoSeguro(cooperativa.nombreComercial) && (
          <p class="mt-1 text-base font-medium text-alcaldia-700">{cooperativa.nombreComercial}</p>
        )}
        <div class="mt-3 flex flex-wrap gap-2">
          {giro && <span class="badge-tipo">{giro}</span>}
          {textoSeguro(cooperativa.subcategoria) && (
            <span class="badge border border-slate-200 bg-white text-slate-700">
              {cooperativa.subcategoria}
            </span>
          )}
        </div>
      </div>
    </div>
  </div>

  <div class="ficha-destacada-grid">
    <div class="ficha-destacada-contenido space-y-8">
      <section>
        <h3 class="text-lg font-semibold text-alcaldia-900">Descripción</h3>
        <p class="mt-2 text-sm leading-relaxed text-slate-600">{descripcionCorta}</p>
        <p class="mt-4 leading-relaxed text-slate-700">{descripcionLarga}</p>
      </section>

      {servicios.length > 0 && (
        <section aria-labelledby="titulo-servicios-coop">
          <h3 id="titulo-servicios-coop" class="text-lg font-semibold text-alcaldia-900">
            Servicios
          </h3>
          <ul class="mt-4 flex flex-wrap gap-2" role="list">
            {servicios.map((item) => (
              <li>
                <span class="badge-servicio">{item}</span>
              </li>
            ))}
          </ul>
        </section>
      )}

      {diferenciador && (
        <section class="rounded-lg border border-alcaldia-100 bg-alcaldia-50 px-4 py-4 sm:px-5">
          <h3 class="text-sm font-semibold uppercase tracking-wide text-alcaldia-700">
            Diferenciador
          </h3>
          <p class="mt-2 text-sm leading-relaxed text-alcaldia-900">{diferenciador}</p>
        </section>
      )}

      {mostrarDemosSpacesig ? (
        <SpacesigDemosPortafolio />
      ) : (
        galeria.length > 0 && (
          <section aria-labelledby="titulo-galeria-coop">
            <h3 id="titulo-galeria-coop" class="text-lg font-semibold text-alcaldia-900">
              Galería
            </h3>
            <div class="mt-4 grid grid-cols-2 gap-3 sm:grid-cols-3">
              {galeria.map((src, i) => (
                <figure class="overflow-hidden rounded-lg border border-slate-200 bg-slate-100">
                  <img
                    src={src}
                    alt={`${cooperativa.nombre} — imagen ${i + 1}`}
                    class="aspect-[4/3] w-full object-cover"
                    width="320"
                    height="240"
                    loading="lazy"
                    onerror={imgErr}
                  />
                </figure>
              ))}
            </div>
          </section>
        )
      )}

      {programas.length > 0 && (
        <section>
          <h3 class="text-lg font-semibold text-alcaldia-900">Programas en los que participa</h3>
          <ul class="mt-3 space-y-2 text-sm text-slate-700">
            {programas.map((p) => (
              <li class="flex items-center gap-2">
                <span class="h-1.5 w-1.5 rounded-full bg-alcaldia-500" aria-hidden="true" />
                {p.nombre}
              </li>
            ))}
          </ul>
        </section>
      )}
    </div>

    <aside class="ficha-destacada-contacto">
      <h3 class="text-lg font-semibold text-alcaldia-900">Contacto</h3>
      <dl class="mt-4 space-y-4 text-sm">
        {zona && (
          <div>
            <dt class="font-medium text-slate-500">Zona</dt>
            <dd class="mt-1 text-slate-800">{zona}</dd>
          </div>
        )}
        {horario && (
          <div>
            <dt class="font-medium text-slate-500">Horario</dt>
            <dd class="mt-1 text-slate-800">{horario}</dd>
          </div>
        )}
        {correo && (
          <div>
            <dt class="font-medium text-slate-500">Correo</dt>
            <dd class="mt-1">
              <a href={`mailto:${correo}`} class="font-medium text-alcaldia-700 hover:underline">
                {correo}
              </a>
            </dd>
          </div>
        )}
        {cooperativa.whatsapp && (
          <div>
            <dt class="font-medium text-slate-500">WhatsApp</dt>
            <dd class="mt-1 text-slate-800">{cooperativa.whatsapp}</dd>
          </div>
        )}
      </dl>

      {sitiosWeb.length > 0 && (
        <div class="mt-6">
          <h4 class="text-sm font-semibold text-alcaldia-900">Sitios web</h4>
          <ul class="mt-2 space-y-2 text-sm">
            {sitiosWeb.map((url) => (
              <li>
                <a
                  href={url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="font-medium text-alcaldia-700 hover:underline"
                  aria-label={`${etiquetaSitio(url)} de ${cooperativa.nombre} (abre en nueva pestaña)`}
                >
                  {etiquetaSitio(url)}
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}

      <div class="mt-6 flex flex-col gap-3">
        {cta && (
          <a
            href={cta.url}
            class="btn-primary w-full text-center"
            target={ctaExterno ? '_blank' : undefined}
            rel={ctaExterno ? 'noopener noreferrer' : undefined}
          >
            {cta.etiqueta}
          </a>
        )}
        {sitioPrincipal && (
          <a
            href={sitioPrincipal}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-secondary w-full text-center"
            aria-label={`Visitar sitio web de ${cooperativa.nombre}`}
          >
            Visitar sitio web
          </a>
        )}
        {whatsappUrl && (
          <a
            href={whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex w-full items-center justify-center rounded-md border border-xochimilco-green bg-white px-4 py-2.5 text-sm font-semibold text-xochimilco-green no-underline hover:bg-xochimilco-green/5"
            aria-label={`Contactar a ${cooperativa.nombre} por WhatsApp`}
          >
            WhatsApp
          </a>
        )}
      </div>
    </aside>
  </div>
</article>
