---
import type { Cooperativa } from '@/types';
import {
  enlaceWhatsapp,
  etiquetaPublica,
  imgOnErrorAttr,
  resolverLogo,
  textoSeguro,
} from '@/lib/cooperativa';

interface Props {
  cooperativa: Cooperativa;
}

const { cooperativa } = Astro.props;
const logoSrc = resolverLogo(cooperativa);
const giro = textoSeguro(cooperativa.giro, 'Sin giro');
const zona = textoSeguro(cooperativa.zona);
const descripcion = textoSeguro(cooperativa.descripcionCorta, 'Sin descripción disponible.');
const correo = textoSeguro(cooperativa.correo);
const whatsapp = textoSeguro(cooperativa.whatsapp);
const whatsappUrl = enlaceWhatsapp(cooperativa.whatsapp);
const etiqueta = etiquetaPublica(cooperativa);
const fichaUrl = `/cooperativas/${cooperativa.slug}`;
const imgErr = imgOnErrorAttr();
---

<article class="card-base flex h-full flex-col">
  <div class="flex items-start gap-3">
    <img
      src={logoSrc}
      alt={`Logotipo de ${cooperativa.nombre}`}
      class="h-14 w-14 shrink-0 rounded-lg bg-slate-100 object-contain p-1"
      width="56"
      height="56"
      loading="lazy"
      onerror={imgErr}
    />
    <div class="min-w-0">
      <p class="text-xs font-semibold uppercase tracking-wide text-xochimilco-green">{etiqueta}</p>
      <h3 class="mt-0.5 text-base font-semibold text-alcaldia-900">
        <a href={fichaUrl} class="no-underline hover:text-alcaldia-700 hover:underline">
          {cooperativa.nombre}
        </a>
      </h3>
    </div>
  </div>

  <p class="mt-3">
    <span class="badge-tipo">{giro}</span>
  </p>

  {zona && (
    <p class="mt-2 text-sm text-slate-600">
      <span class="font-medium">Zona:</span> {zona}
    </p>
  )}

  <p class="mt-2 flex-1 text-sm leading-relaxed text-slate-700 line-clamp-3">{descripcion}</p>

  {(correo || whatsapp) && (
    <dl class="mt-4 space-y-1 border-t border-slate-100 pt-4 text-sm">
      {correo && (
        <div>
          <dt class="sr-only">Correo</dt>
          <dd>
            <a href={`mailto:${correo}`} class="font-medium text-alcaldia-700 hover:underline">
              {correo}
            </a>
          </dd>
        </div>
      )}
      {whatsapp && (
        <div>
          <dt class="sr-only">WhatsApp</dt>
          <dd class="text-slate-600">
            {whatsappUrl ? (
              <a
                href={whatsappUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="font-medium text-alcaldia-700 hover:underline"
              >
                WhatsApp
              </a>
            ) : (
              whatsapp
            )}
          </dd>
        </div>
      )}
    </dl>
  )}

  <a href={fichaUrl} class="btn-secondary mt-4 w-full text-center text-sm">
    Ver ficha
  </a>
</article>
