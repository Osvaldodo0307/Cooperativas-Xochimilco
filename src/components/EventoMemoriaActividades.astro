---
import type { ActividadEventoDetalle } from '@/types';

interface Props {
  actividades: ActividadEventoDetalle[];
  eesys?: boolean;
}

const { actividades, eesys = false } = Astro.props;

const iconos = [
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><path d="M12 3l8 4v6c0 5-3.5 8.5-8 9-4.5-.5-8-4-8-9V7l8-4z"/><path d="M9 12l2 2 4-4"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><path d="M8 10h.01M12 10h.01M16 10h.01M21 12c0 4.418-4.03 8-9 8a9.86 9.86 0 0 1-4-.8L3 20l1.2-3.6A7.7 7.7 0 0 1 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="M8 14l2.5-3 2 2.5L14 11l4 5"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><path d="M3 9l9-6 9 6v11a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V9z"/><path d="M9 21V12h6v9"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><path d="M12 21s7-4.5 7-11a7 7 0 1 0-14 0c0 6.5 7 11 7 11z"/><circle cx="12" cy="10" r="2.5"/></svg>`,
];
---

<section
  class:list={['evento-seccion-card evento-actividades', eesys && 'evento-actividades--eesys']}
  aria-labelledby="titulo-actividades-evento"
>
  <h2 id="titulo-actividades-evento" class="evento-seccion-titulo">Actividades</h2>

  <ul class="evento-actividades-grid" role="list">
    {
      actividades.map((actividad, index) => (
        <li class="evento-actividad-card">
          <span class="evento-actividad-icon" set:html={iconos[index % iconos.length]} />
          <div>
            <h3 class="evento-actividad-titulo">{actividad.titulo}</h3>
            <p class="evento-actividad-desc">{actividad.descripcion}</p>
          </div>
        </li>
      ))
    }
  </ul>
</section>
