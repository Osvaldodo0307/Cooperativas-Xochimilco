---
import type { EventoGaleria } from '@/types';
import { formatFechaSimple } from '@/lib/format';
import {
  fotografiasEvento,
  imgOnErrorEvento,
  resolverPortadaEvento,
} from '@/lib/eventos-galeria';
import AvisoCargaFotografias from '@/components/AvisoCargaFotografias.astro';

interface Props {
  evento: EventoGaleria;
  mostrarAvisoCarga?: boolean;
}

const { evento, mostrarAvisoCarga = true } = Astro.props;

const portada = resolverPortadaEvento(evento);
const fotos = fotografiasEvento(evento);
const fechaTexto = formatFechaSimple(evento.fecha);
const imgErr = imgOnErrorEvento();
---

<section class="galeria-evento" aria-labelledby={`galeria-evento-${evento.id}`}>
  <header class="galeria-evento-cabecera">
    {fechaTexto && (
      <p class="text-sm font-semibold text-alcaldia-800">
        <time datetime={evento.fecha}>{fechaTexto}</time>
      </p>
    )}
    <h2 id={`galeria-evento-${evento.id}`} class="mt-1 text-xl font-semibold text-alcaldia-900 sm:text-2xl">
      {evento.titulo}
    </h2>
    {evento.lugar?.trim() && (
      <p class="mt-1 text-sm text-slate-600">
        <span class="font-medium text-slate-700">Lugar:</span> {evento.lugar}
      </p>
    )}
    {evento.descripcion?.trim() && (
      <p class="mt-3 text-sm leading-relaxed text-slate-700">{evento.descripcion}</p>
    )}
  </header>

  <figure class="galeria-evento-portada mt-6">
    <img
      src={portada}
      alt={`Portada del evento ${evento.titulo}`}
      class="w-full rounded-lg object-cover"
      width="960"
      height="400"
      fetchpriority="high"
      onerror={imgErr}
    />
    <figcaption class="mt-2 text-xs text-slate-500">Imagen principal del evento</figcaption>
  </figure>

  {
    fotos.length > 0 ? (
      <div class="mt-8">
        <h3 class="text-lg font-semibold text-alcaldia-900">
          Fotografías ({fotos.length})
        </h3>
        <ul class="mt-4 grid list-none gap-3 p-0 grid-cols-2 sm:grid-cols-3 lg:grid-cols-4" role="list">
          {fotos.map((src, index) => (
            <li>
              <figure class="overflow-hidden rounded-lg border border-slate-200 bg-slate-100">
                <img
                  src={src}
                  alt={`${evento.titulo} — fotografía ${index + 1}`}
                  class="aspect-square w-full object-cover"
                  width="280"
                  height="280"
                  loading="lazy"
                  onerror={imgErr}
                />
              </figure>
            </li>
          ))}
        </ul>
      </div>
    ) : (
      <div
        class="mt-8 rounded-lg border border-dashed border-slate-300 bg-superficie-muted px-6 py-12 text-center"
        role="status"
      >
        <p class="font-medium text-alcaldia-900">Sin fotografías publicadas</p>
        <p class="mx-auto mt-2 max-w-md text-sm text-slate-600">
          Las imágenes de este evento se integrarán en la carpeta
          <code class="rounded bg-white px-1 py-0.5 text-xs">public/eventos/{evento.id}/</code>
        </p>
      </div>
    )
  }

  {mostrarAvisoCarga && (
    <div class="mt-8">
      <AvisoCargaFotografias carpetaEvento={evento.id} />
    </div>
  )}
</section>
