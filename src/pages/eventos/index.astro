---
import BaseLayout from '@/layouts/BaseLayout.astro';
import EventoGaleriaCard from '@/components/EventoGaleriaCard.astro';
import BloqueProximamente from '@/components/BloqueProximamente.astro';
import { getEventosGaleria } from '@/lib/data';
import { pageCanonical } from '@/lib/seo';

const eventos = getEventosGaleria();

const title = 'Eventos';
const description =
  'Registro de eventos y actividades con cooperativas y actores de la economía social y solidaria en Xochimilco.';
const canonical = pageCanonical('/eventos/', Astro.site);
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <section class="container-main py-8 md:py-12">
    <header class="max-w-3xl">
      <h1 class="section-title">{title}</h1>
      <p class="mt-3 text-base leading-relaxed text-slate-600">
        Consulta los registros de encuentros, jornadas y actividades vinculadas con cooperativas,
        productores locales, artesanos y proyectos de economía social en Xochimilco. Actualmente se
        documenta el 2.º Encuentro de Economía Social y Solidaria como memoria institucional del
        portal.
      </p>
    </header>

    {
      eventos.length > 0 ? (
        <ul
          class="mt-10 grid list-none gap-8 p-0 max-w-5xl"
          role="list"
          aria-label="Eventos publicados"
        >
          {eventos.map((evento) => (
            <li>
              <EventoGaleriaCard evento={evento} />
            </li>
          ))}
        </ul>
      ) : (
        <div class="mt-10">
          <BloqueProximamente
            titulo="Sin eventos publicados"
            mensaje="Próximamente se publicarán nuevas actividades y registros de eventos en la demarcación."
          />
        </div>
      )
    }

    <div class="mt-12 max-w-2xl">
      <BloqueProximamente
        variante="compacto"
        titulo="Más actividades en camino"
        mensaje="Próximamente se publicarán nuevas actividades y convocatorias en la agenda del portal."
      />
    </div>
  </section>
</BaseLayout>
