---
import BaseLayout from '@/layouts/BaseLayout.astro';
import FormularioRegistro from '@/components/FormularioRegistro.astro';
import FormularioEventoApoyo from '@/components/FormularioEventoApoyo.astro';
import { pageCanonical } from '@/lib/seo';

const title = 'Registro y publicaciones';
const description =
  'Registra tu cooperativa en el directorio o solicita publicar un evento o convocatoria de apoyo en el portal institucional de Cooperativas Xochimilco.';
const canonical = pageCanonical('/registro/', Astro.site);
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <section class="container-main py-8 md:py-12">
    <header class="max-w-2xl">
      <h1 class="section-title">{title}</h1>
      <p class="mt-3 text-base leading-relaxed text-slate-600">
        Usa los formularios para solicitar el alta de tu cooperativa en el directorio o proponer un
        evento o apoyo para publicar en el portal. Todos los envíos son revisados por el equipo de
        enlace.
      </p>
    </header>

    <p id="aviso-privacidad-registro" class="notice-privacy mt-6 max-w-3xl">
      <strong class="text-institucional-900">Privacidad:</strong> Los datos personales y de contacto
      se tratan conforme al
      <a href="/aviso-privacidad" class="font-medium text-institucional-700 underline">
        aviso de privacidad
      </a>
      . Solo proporciona información que autorices publicar en el directorio.
    </p>

    <div class="mt-10 space-y-14">
      <section id="registro-cooperativa" class="mx-auto max-w-2xl" aria-labelledby="titulo-registro-cooperativa">
        <h2 id="titulo-registro-cooperativa" class="text-xl font-semibold text-institucional-900">
          1. Registro de cooperativa
        </h2>
        <p id="desc-registro-cooperativa" class="mt-2 text-sm text-slate-600">
          Solicita incorporar tu cooperativa al directorio público. Campos marcados con * son
          obligatorios.
        </p>
        <div class="form-panel mt-6">
          <FormularioRegistro describedBy="desc-registro-cooperativa aviso-privacidad-registro" />
        </div>
      </section>

      <section
        id="publicacion-evento-apoyo"
        class="mx-auto max-w-2xl border-t border-slate-200 pt-14"
        aria-labelledby="titulo-publicacion-evento"
      >
        <h2 id="titulo-publicacion-evento" class="text-xl font-semibold text-institucional-900">
          2. Publicación de evento o apoyo
        </h2>
        <p id="desc-publicacion-evento" class="mt-2 text-sm text-slate-600">
          Propón un evento para la agenda o un apoyo/convocatoria para la sección correspondiente.
        </p>
        <div class="form-panel mt-6">
          <FormularioEventoApoyo describedBy="desc-publicacion-evento aviso-privacidad-registro" />
        </div>
      </section>
    </div>
  </section>
</BaseLayout>
